# ---------------------------------------------------------------
# Leitura e limpeza
# ---------------------------------------------------------------

def ler_excel(caminho, aba):
    try:
        return pd.read_excel(caminho, sheet_name=aba)
    except (PermissionError, OSError):
        destino = os.path.join(tempfile.gettempdir(), os.path.basename(caminho))
        shutil.copy2(caminho, destino)
        print(f"  aviso: arquivo travado, lendo copia em {destino}")
        return pd.read_excel(destino, sheet_name=aba)


def padronizar_colunas(df):
    df = df.copy()
    df.columns = [str(c).strip() for c in df.columns]
    existentes = set(df.columns)
    mapa_seguro = {}
    for origem, destino in MAPA_COLUNAS.items():
        if origem in existentes and destino not in existentes:
            mapa_seguro[origem] = destino
            existentes.add(destino)
    return df.rename(columns=mapa_seguro)


def resolver_duplicatas(df, nome_base=""):
    dups = df.columns[df.columns.duplicated()].unique()
    if len(dups):
        print(f"  aviso ({nome_base}): colunas duplicadas removidas: {list(dups)}")
    return df.loc[:, ~df.columns.duplicated()]


def normalizar_chave(serie):
    if isinstance(serie, pd.DataFrame):
        serie = serie.iloc[:, 0]
    return (
        serie.astype(str).str.strip().str.upper()
        .str.replace(r"\s+", " ", regex=True)
        .str.normalize("NFKD").str.encode("ascii", errors="ignore").str.decode("utf-8")
    )


def preparar_chaves(df):
    df = df.copy()
    df["_cat"] = normalizar_chave(df["Category SAP"])
    df["_sub"] = normalizar_chave(df["SUB"])
    df["_cust"] = normalizar_chave(df["Customer"])
    return df


def preparar_periodo(df, col_data=None, col_ano=None, col_mes=None):
    df = df.copy()
    if col_data is not None:
        col = df[col_data]
        if pd.api.types.is_datetime64_any_dtype(col):
            data = col
        else:
            # Detecta o formato pelo separador: ISO (2024-01-15) nao usa
            # dayfirst; brasileiro (15/01/2024) usa. Forcar dayfirst num
            # texto ISO troca dia e mes.
            amostra = col.dropna().astype(str).head(20)
            usa_dayfirst = amostra.str.contains("/").any()
            data = pd.to_datetime(col, errors="coerce", dayfirst=usa_dayfirst)
        df["_ano"] = data.dt.year
        df["_mes"] = data.dt.month
    else:
        df["_ano"] = pd.to_numeric(df[col_ano], errors="coerce")
        df["_mes"] = pd.to_numeric(df[col_mes], errors="coerce")
    df["_ano"] = df["_ano"].astype("Int64")
    df["_mes"] = df["_mes"].astype("Int64")
    return df


# Chave inclui Customer e Mes para permitir filtro no navegador.
CHAVES = ["_cust", "_cat", "_sub", "_ano", "_mes"]


# ---------------------------------------------------------------
# Agregacao mantendo Customer e Mes
# ---------------------------------------------------------------

def agregar_vendas(df, col_valor="Valor", col_su="SU"):
    return (
        df.groupby(CHAVES, dropna=False)
        .agg(faturamento=(col_valor, "sum"), su=(col_su, "sum"))
        .reset_index()
    )


def agregar_sell(df):
    candidatas = ["MSU", "Valor"]
    presentes = [c for c in candidatas if c in df.columns]
    mapa = {f"sell_{c}": (c, "sum") for c in presentes}
    return df.groupby(CHAVES, dropna=False).agg(**mapa).reset_index()


def cruzar(vendas_agg, sell_agg):
    merged = vendas_agg.merge(sell_agg, on=CHAVES, how="outer", indicator=True)
    diag = {
        "casaram": int((merged["_merge"] == "both").sum()),
        "so_vendas": int((merged["_merge"] == "left_only").sum()),
        "so_sell": int((merged["_merge"] == "right_only").sum()),
    }
    total = sum(diag.values())
    diag["pct_casou"] = round(diag["casaram"] / total * 100, 1) if total else 0
    return merged, diag


def comparar_dominios(vendas, sell, coluna="_cat"):
    a = set(vendas[coluna].dropna().unique())
    b = set(sell[coluna].dropna().unique())
    return {"so_em_vendas": sorted(a - b), "so_em_sell": sorted(b - a), "em_ambas": sorted(a & b)}


# ---------------------------------------------------------------
# Preparacao dos dados para o navegador
# ---------------------------------------------------------------

def preparar_dados_dashboard(merged, ano_atual):
    """
    Exporta linhas detalhadas (Customer + Mes + Categoria) com valores do ano
    atual e do anterior, para o navegador recalcular sob os filtros.
    """
    at = merged[merged["_ano"] == ano_atual].copy()
    an = merged[merged["_ano"] == ano_atual - 1].copy()

    chave_ant = ["_cust", "_mes", "_cat"]
    ant = an.groupby(chave_ant, dropna=False).agg(
        fat_ant=("faturamento", "sum"), su_ant=("su", "sum")
    ).reset_index()

    at = at.groupby(["_cust", "_mes", "_cat"], dropna=False).agg(
        fat=("faturamento", "sum"),
        su=("su", "sum"),
        msu=("sell_MSU", "sum") if "sell_MSU" in merged.columns else ("faturamento", "size"),
        valor_sell=("sell_Valor", "sum") if "sell_Valor" in merged.columns else ("faturamento", "size"),
    ).reset_index()

    dados = at.merge(ant, on=chave_ant, how="left")
    dados["mes_nome"] = dados["_mes"].map(lambda m: MESES_NOME.get(int(m), str(m)) if pd.notna(m) else "?")

    registros = []
    for _, r in dados.iterrows():
        registros.append({
            "customer": r["_cust"],
            "mes": int(r["_mes"]) if pd.notna(r["_mes"]) else 0,
            "mesNome": r["mes_nome"],
            "cat": r["_cat"],
            "fat": float(r["fat"]) if pd.notna(r["fat"]) else 0,
            "su": float(r["su"]) if pd.notna(r["su"]) else 0,
            "msu": float(r["msu"]) if pd.notna(r["msu"]) else 0,
            "valorSell": float(r["valor_sell"]) if pd.notna(r["valor_sell"]) else 0,
            "fatAnt": float(r["fat_ant"]) if pd.notna(r["fat_ant"]) else 0,
            "suAnt": float(r["su_ant"]) if pd.notna(r["su_ant"]) else 0,
        })
    return registros


