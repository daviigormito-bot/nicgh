def executar():
    print("Lendo Base_Srm_Modelo...")
    vendas = resolver_duplicatas(padronizar_colunas(ler_excel(CAMINHO_VENDAS, ABA_VENDAS)), "Base_Srm_Modelo")
    print("Lendo sellin...")
    sell = resolver_duplicatas(padronizar_colunas(ler_excel(CAMINHO_SELL, ABA_SELL)), "sellin")

    print("\nCOLUNAS Base_Srm_Modelo:", list(vendas.columns))
    print("COLUNAS sellin:", list(sell.columns))

    for nome, df in [("Base_Srm_Modelo", vendas), ("sellin", sell)]:
        faltando = [c for c in ["Category SAP", "SUB", "Customer"] if c not in df.columns]
        if faltando:
            print(f"\nERRO: {nome} sem colunas {faltando}. Adicione ao MAPA_COLUNAS.")
            return None

    vendas = preparar_chaves(vendas)
    sell = preparar_chaves(sell)

    if "Data" in vendas.columns:
        vendas = preparar_periodo(vendas, col_data="Data")
    else:
        vendas = preparar_periodo(vendas, col_ano="Ano", col_mes="Mês")
    if "Ano" in sell.columns and "Mês" in sell.columns:
        sell = preparar_periodo(sell, col_ano="Ano", col_mes="Mês")
    else:
        sell = preparar_periodo(sell, col_data="Data")

    dominios = comparar_dominios(vendas, sell)
    merged, diag = cruzar(agregar_vendas(vendas), agregar_sell(sell))

    print("\n" + "=" * 60)
    print("DIAGNOSTICO DO MERGE")
    print("=" * 60)
    for k, v in diag.items():
        print(f"  {k}: {v}")
    print(f"\nCATEGORY SAP so em Base_Srm_Modelo: {dominios['so_em_vendas'][:30]}")
    print(f"CATEGORY SAP so em sellin: {dominios['so_em_sell'][:30]}")
    print(f"CATEGORY SAP em ambas: {dominios['em_ambas'][:30]}")

    registros = preparar_dados_dashboard(merged, ANO_ATUAL)
    caminho = gerar_dashboard_html(registros, diag, dominios)

    print("\n" + "=" * 60)
    print("ARQUIVOS GERADOS")
    print("=" * 60)
    print(f"  Dashboard: {caminho}")
    print("\nNo terminal, digite:  start dashboard_srm.html")


if __name__ == "__main__":
    executar()
