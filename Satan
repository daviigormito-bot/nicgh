function corSRM(srm) {
  if (srm == null || isNaN(srm)) return "";
  const i = Math.min(Math.abs(srm) / 20, 1);
  const a = (0.15 + i * 0.75).toFixed(2);
  const fg = i > 0.45 ? "#fff" : (srm >= 0 ? "#123f2e" : "#5c1616");
  const bg = srm >= 0 ? "rgba(31,122,90," + a + ")" : "rgba(176,48,48," + a + ")";
  return "background:" + bg + ";color:" + fg + ";font-weight:600";
}

function filtrar() {
  return DADOS.filter(d =>
    (fCustomer === "TODOS" || d.customer === fCustomer) &&
    (fMes === "TODOS" || d.mesNome === fMes));
}

function agregarPorCategoria(linhas) {
  const mapa = new Map();
  for (const l of linhas) {
    if (!mapa.has(l.cat)) mapa.set(l.cat, {cat: l.cat, fat:0, su:0, msu:0, valorSell:0, fatAnt:0, suAnt:0});
    const a = mapa.get(l.cat);
    a.fat += l.fat; a.su += l.su; a.msu += l.msu;
    a.valorSell += l.valorSell; a.fatAnt += l.fatAnt; a.suAnt += l.suAnt;
  }
  return [...mapa.values()];
}

function medidas(a, totalFat) {
  const precoMedio = a.su ? a.fat / a.su : null;
  const iValor = a.fatAnt ? (a.fat / a.fatAnt) * 100 : null;
  const iSU = a.suAnt ? (a.su / a.suAnt) * 100 : null;
  const srm = (iValor != null && iSU != null) ? iValor - iSU : null;
  const bz = totalFat ? (a.fat / totalFat) * 100 : null;
  return {precoMedio, srm, bz};
}

