# ==============================================================================
# 5. LÓGICA DE STATUS: COMPARAÇÃO SEQUENCIAL (MÊS VS MÊS SEGUINTE)
# ==============================================================================
print("Analisando o comportamento das combinações de NF e Valor contra o mês seguinte...")

# 1. Identifica a linha do tempo ordenada dos meses presentes na base
meses_ordenados = sorted(df_tracking_critico['MES_REFERENCIA'].unique())
mes_mais_recente = meses_ordenados[-1]
print(f"➔ Linha do tempo identificada: {meses_ordenados}")

# Criamos a chave identitária única arredondada para evitar erros de float
df_tracking_critico['CHAVE_NF_VALOR'] = (
    df_tracking_critico['NF'].astype(str) + '_V_' + df_tracking_critico['VALOR'].round(2).astype(str)
)

# Criamos uma lista para armazenar os sub-dataframes processados
df_processado_lista = []

# 2. Varre cada mês comparando com o seu respectivo mês seguinte
for i, mes_atual in enumerate(meses_ordenados):
    df_mes = df_tracking_critico[df_tracking_critico['MES_REFERENCIA'] == mes_atual].copy()
    
    # Se for o último mês da pasta (Junho), não há mês seguinte para comparar. Ele apenas soma tudo.
    if mes_atual == mes_mais_recente:
        df_mes['STATUS_RESOLUCAO'] = 'Não Resolvido'
    else:
        # Identifica qual é o mês imediatamente seguinte na sequência
        mes_seguinte = meses_ordenados[i + 1]
        
        # Captura as chaves que estavam ativas no mês seguinte
        chaves_mes_seguinte = df_tracking_critico[
            df_tracking_critico['MES_REFERENCIA'] == mes_seguinte
        ]['CHAVE_NF_VALOR'].unique()
        
        # Se a combinação exata continuou no mês seguinte ➔ 'Não Resolvido'. Se sumiu ➔ 'Resolvido'.
        df_mes['STATUS_RESOLUCAO'] = np.where(
            df_mes['CHAVE_NF_VALOR'].isin(chaves_mes_seguinte),
            'Não Resolvido',
            'Resolvido'
        )
        
    df_processado_lista.append(df_mes)

# Reconstrói a base unificada com os status corrigidos sequencialmente
df_tracking_critico = pd.concat(df_processado_lista, ignore_index=True)
df_tracking_critico = df_tracking_critico.drop(columns=['CHAVE_NF_VALOR'])
